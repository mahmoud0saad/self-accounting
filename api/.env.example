# Copy to `api/.env` for local development.
# Start MySQL first: from `api/` run `npm run db:up` (or repo root: `docker compose up -d --wait`).
DATABASE_URL="mysql://muhasabah:muhasabah@localhost:3306/muhasabah_dev"
SHADOW_DATABASE_URL="mysql://muhasabah:muhasabah@localhost:3306/muhasabah_shadow"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Public URL for email confirmation links (no trailing slash)
APP_PUBLIC_URL="http://localhost:3000"

# Mail: smtp (default) | resend
MAIL_PROVIDER="smtp"
SMTP_FROM_NAME="Muhasabah"

# SMTP (Gmail App Password for anti.mahmoud.saad.6@gmail.com)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="anti.mahmoud.saad.6@gmail.com"
SMTP_PASSWORD="onif mitf jmwq lldg"

# Resend (set MAIL_PROVIDER=resend). Replace with your real API key from https://resend.com/api-keys
RESEND_API_KEY="re_eLmcUrEb_6ZKaijPb744GDxN3U2LLzQNS"
RESEND_FROM="noreply@saad-co.online"

# Comma-separated CORS origins. `http://localhost` / `http://127.0.0.1` (no port) allow any port (Flutter web).
CORS_ORIGINS="http://localhost,http://127.0.0.1,http://localhost:3000,http://localhost:8080"

PORT=3000
