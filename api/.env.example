# Copy to `api/.env` for local development.
DATABASE_URL="mysql://muhasabah:muhasabah@localhost:3306/muhasabah_dev"
# Used by `prisma migrate dev` (shadow DB). Created by `docker/mysql/init.sql` on first MySQL volume init.
SHADOW_DATABASE_URL="mysql://muhasabah:muhasabah@localhost:3306/muhasabah_shadow"
